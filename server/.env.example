# Copy to .env and fill in values
# AWS credentials — leave blank to use ~/.aws/credentials or IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Secrets Manager ARN for OpenAI key
OPENAI_SECRET_ARN=arn:aws:secretsmanager:us-east-1:740315635748:secret:openai_api_key-N4gRLQ

# JWT signing secret (any random long string)
JWT_SECRET=change-me-to-a-long-random-string

# Server port
PORT=3001

# ── Confluence (optional) — when set, Teams bot AI answers use live wiki pages ──
# Base URL must include /wiki, e.g. https://aheadcloudservices.atlassian.net/wiki
CONFLUENCE_BASE_URL=
# Atlassian account email + API token (https://id.atlassian.com/manage-profile/security/api-tokens)
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
#
# Prefer explicit page IDs (comma-separated, order preserved). IDs are the numbers in /pages/12345/...
# Example: General Onboarding + AI Practice Onboarding Document (ABL space)
# CONFLUENCE_PAGE_IDS=3670048770,3667951637
# If CONFLUENCE_PAGE_IDS is set, CQL search below is ignored.
#
# Optional: CQL search when PAGE_IDS is empty (defaults: ABL + title~"Onboarding")
# CONFLUENCE_CQL=space=ABL AND title~"Onboarding" ORDER BY lastmodified DESC
# Or target specific pages: id in (3670048770,3667951637)
# CONFLUENCE_SEARCH_LIMIT=10
# Cache fetched wiki text in memory (ms). Use 0 to disable cache (always refetch).
# CONFLUENCE_CACHE_TTL_MS=300000
