# Copy this file to .env and fill in the values

# From Azure Bot Service (portal.azure.com > App Registrations > your app)
MICROSOFT_APP_ID=your-microsoft-app-id
MICROSOFT_APP_PASSWORD=your-microsoft-app-password

# Shared secret between bot and backend (must match BOT_SECRET on the backend)
# In production this comes from AWS Secrets Manager via ECS task definition
BOT_SECRET=generate-a-random-secret-here

# URL of the Express backend
# Local development:  http://localhost:3001
# Production (ECS):   http://localhost:3001  (same task, shared network)
BACKEND_URL=http://localhost:3001

# Port for the bot server (Azure Bot Service will call this webhook)
PORT=3978
